{
  "title": "Unified API Connector Structure",
  "description": "Field-level documentation for a Unified API Connector entity.",
  "type": "object",
  "fields": [
    { "name": "connectorId", "type": "string", "required": true, "description": "Unique slug identifier (e.g., salesforce-crm)" },
    { "name": "name", "type": "string", "required": true, "description": "Human-readable connector name" },
    { "name": "description", "type": "string", "required": false, "description": "What the connector does and normalizes" },
    { "name": "provider", "type": "string", "required": true, "description": "Upstream API provider name" },
    { "name": "providerUrl", "type": "uri", "required": false, "description": "Upstream API documentation URL" },
    { "name": "category", "type": "enum", "required": true, "description": "Unified API vertical category",
      "values": ["crm", "hris", "ats", "accounting", "file-storage", "ticketing", "marketing-automation", "ecommerce", "payroll", "banking", "payments", "data-pipeline", "communication", "project-management", "other"] },
    { "name": "authType", "type": "enum", "required": false, "description": "Authentication method used",
      "values": ["oauth2", "api-key", "basic", "oauth1", "jwt", "custom"] },
    { "name": "dataObjects", "type": "array<string>", "required": false, "description": "Normalized data objects exposed (e.g., Contact, Deal, Employee)" },
    { "name": "supportedOperations", "type": "array<enum>", "required": false, "description": "CRUD operations supported" },
    { "name": "webhookSupport", "type": "boolean", "required": false, "description": "Whether real-time webhooks are supported" },
    { "name": "fieldMapping", "type": "object", "required": false, "description": "Normalized to provider-specific field mappings" },
    { "name": "sandboxAvailable", "type": "boolean", "required": false, "description": "Whether a sandbox is available" },
    { "name": "status", "type": "enum", "required": false, "description": "ga, beta, alpha, or deprecated" }
  ]
}
